# Copy this file to ".env.local" and adjust values.
# Next.js loads .env.local automatically
# Browser + client code may only read variables prefixed with NEXT_PUBLIC_.

# API base URL for the Nur backend (no trailing slash).
# Local: http://localhost:4000
# Production: https://nur-server.vercel.app
NEXT_PUBLIC_API_URL=http://localhost:4000

